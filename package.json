{
  "name": "notion-docs-tracker-rewrite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "module": "./src/index.ts",
  "scripts": {
    "start": "bun ./src/index.ts --send-telegram=false --save-content=true",
    "sync": "bun ./src/index.ts --send-telegram=false --save-content=true",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@notionhq/client": "^5.15.0",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-mdast": "^10.1.2",
    "linkedom": "^0.18.12",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/yargs": "^17.0.35",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {}
}
